{
  "name": "docxengine",
  "version": "0.0.0",
  "private": true,
  "description": "An AI-optimized DOCX manipulation engine: one deterministic OOXML core exposed as an MCP server and framework-agnostic Python/JS tools.",
  "homepage": "https://github.com/ruwadgroup/docxengine#readme",
  "bugs": {
    "url": "https://github.com/ruwadgroup/docxengine/issues"
  },
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwadgroup/docxengine.git"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{md,json,yaml,yml}\"",
    "lint:docs": "prettier --check \"**/*.{md,json,yaml,yml}\"",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3"
  },
  "lint-staged": {
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}

{
  "doc": "tables",
  "tool": "docx_table",
  "args": {
    "op": "style",
    "anchor": "T1",
    "props": {
      "borders": false,
      "width_pct": 100,
      "align": "center",
      "col_widths": [3000, 3000, 3000]
    }
  },
  "expect": {
    "result": { "note": "Styled table." },
    "invariants": ["no_word_repair"],
    "output_contains": {
      "word/document.xml": {
        "present": [
          "<w:tblBorders><w:top w:val=\"none\"",
          "<w:tblW w:w=\"5000\" w:type=\"pct\"/>",
          "<w:jc w:val=\"center\"/>",
          "<w:tblLayout w:type=\"fixed\"/>",
          "<w:gridCol w:w=\"3000\"/>"
        ],
        "absent_in_input": ["<w:tblLayout w:type=\"fixed\"/>"]
      }
    }
  }
}
